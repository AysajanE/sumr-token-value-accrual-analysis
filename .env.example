# Base chain RPC (archive node required for historical state reads)
# Options: Alchemy, QuickNode, Ankr
BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY

# BaseScan API key (for ABI fetching and contract metadata)
BASESCAN_API_KEY=YOUR_BASESCAN_API_KEY

# DeFiLlama (no key required, but set base URL for convenience)
DEFILLAMA_BASE_URL=https://api.llama.fi
