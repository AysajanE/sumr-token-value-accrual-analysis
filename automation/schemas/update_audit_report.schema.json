{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "UpdateCycleAuditReport",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "phase",
    "agent",
    "verdict",
    "summary",
    "findings",
    "checks",
    "commands_run",
    "artifacts",
    "limitations",
    "next_actions"
  ],
  "properties": {
    "phase": {
      "type": "string"
    },
    "agent": {
      "type": "string",
      "enum": [
        "codex",
        "claude"
      ]
    },
    "verdict": {
      "type": "string",
      "enum": [
        "pass",
        "pass_with_minor",
        "conditional_pass",
        "fail",
        "blocked"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "severity",
          "title",
          "description",
          "impact",
          "evidence",
          "recommendation",
          "file_refs"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "severity": {
            "type": "string",
            "enum": [
              "critical",
              "high",
              "medium",
              "low",
              "info"
            ]
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "impact": {
            "type": "string",
            "minLength": 1
          },
          "evidence": {
            "type": "string",
            "minLength": 1
          },
          "recommendation": {
            "type": "string",
            "minLength": 1
          },
          "file_refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "status",
          "details"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "pass",
              "fail",
              "not_run"
            ]
          },
          "details": {
            "type": "string"
          }
        }
      }
    },
    "commands_run": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "next_actions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
